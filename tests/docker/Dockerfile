# Test-only image: AlmaLinux 8 with sshd + PAM, used to automate the checks
# from docs/manual-verification.md that need a real SSH/PAM stack. Not part
# of the deployed artifact — see tests/docker/run-docker-verification.sh.
FROM almalinux:8

RUN dnf install -y openssh-server passwd shadow-utils \
    && dnf clean all \
    && ssh-keygen -A

RUN useradd -m testuser \
    && mkdir -p /root/.ssh /home/testuser/.ssh \
    && chmod 700 /root/.ssh /home/testuser/.ssh

# Ephemeral public key generated by run-docker-verification.sh for this test
# run only; never a real credential, not committed to git.
COPY tests/docker/id_test.pub /root/.ssh/authorized_keys
COPY tests/docker/id_test.pub /home/testuser/.ssh/authorized_keys
RUN chmod 600 /root/.ssh/authorized_keys /home/testuser/.ssh/authorized_keys \
    && chown testuser:testuser /home/testuser/.ssh/authorized_keys

COPY install.sh /opt/ssh-history-wipe/install.sh
COPY files/ /opt/ssh-history-wipe/files/
RUN chmod +x /opt/ssh-history-wipe/install.sh /opt/ssh-history-wipe/files/wipe-history-on-logout.sh \
    && bash /opt/ssh-history-wipe/install.sh

# PasswordAuthentication off: the test harness only ever uses the ephemeral
# key above. ClientAliveInterval/CountMax shortened so the abrupt-disconnect
# check (spec §3, §6) completes in seconds instead of the production default.
RUN sed -i \
      -e 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' \
      -e 's/^#\?PasswordAuthentication.*/PasswordAuthentication no/' \
      -e 's/^#\?PubkeyAuthentication.*/PubkeyAuthentication yes/' \
      -e 's/^#\?UsePAM.*/UsePAM yes/' \
      -e 's/^#\?ClientAliveInterval.*/ClientAliveInterval 2/' \
      -e 's/^#\?ClientAliveCountMax.*/ClientAliveCountMax 1/' \
      /etc/ssh/sshd_config \
    && chown testuser:testuser /home/testuser/.ssh

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D", "-e"]
